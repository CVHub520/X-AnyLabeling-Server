      "post": {
        "description": "Clean up and remove a video session.\n\nArgs:\n    session_id: Session identifier.\n    model: Model identifier.\n\nReturns:\n    Success response or error response.",
        "operationId": "cleanup_video_session_v1_video_cleanup__session_id__post",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "title": "Session Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "model",
            "required": true,
            "schema": {
              "title": "Model",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
